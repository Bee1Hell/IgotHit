<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- ============================================================
	     Adrenaline Rush: triggered when hit with pain > 20%, lasts 2 hours
	     ============================================================ -->
	<HediffDef>
		<defName>AdrenalineRush</defName>
		<label>Adrenaline Rush</label>
		<description>The pawn's body floods with adrenaline in response to intense pain, dulling the sensation of pain and enhancing physical performance to a degree. However, the side effects of surging adrenaline also impair the pawn's fine motor control and perception.</description>
		<hediffClass>IgotHit.Hediff_AdrenalineRush</hediffClass>
		<maxSeverity>1.0</maxSeverity>
		<stages>

			<!-- Stage 1 Minor: pain x90%, move speed x105% -->
			<li>
				<label>minor</label>
				<painFactor>0.9</painFactor>
				<statFactors>
					<MoveSpeed>1.05</MoveSpeed>
				</statFactors>
			</li>

			<!-- Stage 2 Light: pain x80%, move speed x110%, manipulation x95% -->
			<li>
				<minSeverity>0.25</minSeverity>
				<label>light</label>
				<painFactor>0.8</painFactor>
				<statFactors>
					<MoveSpeed>1.10</MoveSpeed>
				</statFactors>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<postFactor>0.95</postFactor>
					</li>
				</capMods>
			</li>

			<!-- Stage 3 Moderate: pain x60%, move speed x120%, manipulation x90%, sight x90%, rest x50% -->
			<li>
				<minSeverity>0.50</minSeverity>
				<label>moderate</label>
				<painFactor>0.6</painFactor>
				<statFactors>
					<MoveSpeed>1.20</MoveSpeed>
				</statFactors>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<postFactor>0.90</postFactor>
					</li>
					<li>
						<capacity>Sight</capacity>
						<postFactor>0.90</postFactor>
					</li>
				</capMods>
				<restFallFactor>0.50</restFallFactor>
			</li>

			<!-- Stage 4 Severe: pain x50%, move speed x125%, manipulation x80%, sight x80%, rest x25% -->
			<li>
				<minSeverity>0.75</minSeverity>
				<label>severe</label>
				<painFactor>0.5</painFactor>
				<statFactors>
					<MoveSpeed>1.25</MoveSpeed>
				</statFactors>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<postFactor>0.80</postFactor>
					</li>
					<li>
						<capacity>Sight</capacity>
						<postFactor>0.80</postFactor>
					</li>
				</capMods>
				<restFallFactor>0.25</restFallFactor>
			</li>

			<!-- Stage 5 Extreme: pain x20%, move speed x125%, manipulation x60%, sight x70%, rest x0% -->
			<li>
				<minSeverity>0.90</minSeverity>
				<label>extreme</label>
				<painFactor>0.2</painFactor>
				<statFactors>
					<MoveSpeed>1.25</MoveSpeed>
				</statFactors>
				<capMods>
					<li>
						<capacity>Manipulation</capacity>
						<postFactor>0.60</postFactor>
					</li>
					<li>
						<capacity>Sight</capacity>
						<postFactor>0.70</postFactor>
					</li>
				</capMods>
				<restFallFactor>0.0</restFallFactor>
			</li>

		</stages>
	</HediffDef>

	<!-- ============================================================
	     Adrenaline Cooldown: lasts 1 day, prevents triggering a new rush
	     ============================================================ -->
	<HediffDef>
		<defName>AdrenalineCooldown</defName>
		<label>Adrenaline Rush Cooldown</label>
		<description>The pawn's adrenal system is recovering from a recent adrenaline rush and cannot trigger another surge for some time.</description>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-1.0</severityPerDay>
			</li>
		</comps>
	</HediffDef>

</Defs>
